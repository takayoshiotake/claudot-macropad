{
    "keyboard_name": "Claudot",
    "maintainer": "takayoshiotake",
    "manufacturer": "takayoshiotake",
    "url": "https://github.com/takayoshiotake/claudot-macropad",
    "processor": "RP2040",
    "bootloader": "rp2040",
    "usb": {
        "device_version": "1.0.0",
        "pid": "0x8CAE",
        "vid": "0x1209",
        "force_nkro": true
    },
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "mousekey": true,
        "nkro": true
    },
    "diode_direction": "COL2ROW",
    "matrix_pins": {
        "cols": ["GP18", "GP19", "GP20", "GP21"],
        "rows": ["GP23", "GP22", "GP24"]
    },
    "layouts": {
        "LAYOUT": {
            "layout": [
                { "matrix": [0, 0], "x": 0, "y": 0 },
                { "matrix": [0, 1], "x": 1, "y": 0 },
                { "matrix": [0, 2], "x": 2, "y": 0 },
                { "matrix": [0, 3], "x": 3, "y": 0 },
                { "matrix": [1, 0], "w": 1.25, "x": 0, "y": 1 },
                { "matrix": [1, 1], "x": 1.25, "y": 1 },
                { "matrix": [1, 2], "x": 2.25, "y": 1 },
                { "matrix": [1, 3], "x": 3.25, "y": 1 },
                { "matrix": [2, 0], "w": 1.75, "x": 0, "y": 2 },
                { "matrix": [2, 1], "w": 2.75, "x": 1.75, "y": 2 },
                { "matrix": [2, 2], "x": 4.5, "y": 2 },
                { "matrix": [2, 3], "w": 1.25, "h": 2, "x": 4.25, "y": 0 }
            ]
        }
    }
}
